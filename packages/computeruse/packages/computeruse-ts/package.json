{
  "name": "@elizaos/computeruse",
  "author": "elizaos",
  "bugs": {
    "url": "https://github.com/elizaos/eliza/issues"
  },
  "dependencies": {
    "@mediar-ai/kv": "^0.23.30"
  },
  "description": "Node.js/TypeScript bindings for the ComputerUse Rust library (via napi-rs)",
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "esbuild": "^0.25.11"
  },
  "engines": {
    "node": ">= 10"
  },
  "homepage": "https://github.com/elizaos/eliza",
  "keywords": [
    "napi",
    "rust",
    "native",
    "computeruse",
    "automation",
    "desktop",
    "gui",
    "ui",
    "testing",
    "windows",
    "macos",
    "linux"
  ],
  "main": "wrapper.js",
  "files": [
    "index.js",
    "index.d.ts",
    "wrapper.js",
    "wrapper.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "napi": {
    "name": "computeruse",
    "triples": {
      "additional": [
        "aarch64-pc-windows-msvc",
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "optionalDependencies": {
    "@elizaos/computeruse-darwin-arm64": "2.0.0-alpha.3",
    "@elizaos/computeruse-darwin-x64": "2.0.0-alpha.3",
    "@elizaos/computeruse-linux-arm64-gnu": "2.0.0-alpha.3",
    "@elizaos/computeruse-linux-x64-gnu": "2.0.0-alpha.3",
    "@elizaos/computeruse-win32-arm64-msvc": "2.0.0-alpha.3",
    "@elizaos/computeruse-win32-x64-msvc": "2.0.0-alpha.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaos/eliza"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "npm run build:wrapper && napi build --platform --release --strip",
    "build:debug": "npm run build:wrapper && napi build --platform",
    "build:wrapper": "esbuild wrapper.ts --outfile=wrapper.js --platform=node --format=cjs --target=es2020",
    "prepublish:ci": "npm run build:wrapper",
    "prepublishOnly": "npm run build:wrapper && napi prepublish -t npm",
    "sync-version": "node scripts/sync-version.js",
    "test": "node tests/element-chaining.test.js && node tests/element-range.test.js && node tests/element-scroll-into-view.test.js && node tests/element-value.test.js && node tests/execute-browser-script-wrapper.test.js && node tests/comprehensive-ui-elements.test.js",
    "test:desktop": "node --test tests/*.test.js",
    "test-hook": "powershell.exe -ExecutionPolicy Bypass -File \"../../.git/hooks/pre-push.ps1\""
  },
  "types": "wrapper.d.ts",
  "version": "2.0.0-alpha.32"
}
